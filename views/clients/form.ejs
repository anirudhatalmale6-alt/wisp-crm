<%- include('../partials/header', { currentPage: 'clients', pageTitle: client ? 'Editar Cliente' : 'Nuevo Cliente' }) %>

<% const currency = (settings && settings.currency) ? settings.currency : '$'; %>
<% const isEdit = !!client; %>
<% const c = client || {}; %>

<!-- Breadcrumb -->
<div class="flex items-center gap-2 text-sm text-gray-500 mb-6">
  <a href="/clients" class="hover:text-wisp-600 transition-colors">Clientes</a>
  <i class="fas fa-chevron-right text-xs"></i>
  <span class="text-gray-700 font-medium"><%= isEdit ? 'Editar' : 'Nuevo' %> Cliente</span>
</div>

<form method="POST" action="<%= isEdit ? '/clients/' + c.id : '/clients' %>" class="space-y-6">

  <!-- Personal Information -->
  <div class="bg-white rounded-xl shadow-sm border">
    <div class="px-5 py-4 border-b bg-gray-50 rounded-t-xl">
      <h3 class="font-semibold text-gray-700 flex items-center gap-2">
        <i class="fas fa-user text-wisp-600"></i> Información Personal
      </h3>
    </div>
    <div class="p-5 grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- First Name -->
      <div>
        <label for="first_name" class="block text-sm font-medium text-gray-700 mb-1">Nombre <span class="text-red-500">*</span></label>
        <input type="text" id="first_name" name="first_name" value="<%= c.first_name || '' %>" required
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none"
          placeholder="Nombre del cliente">
      </div>

      <!-- Last Name -->
      <div>
        <label for="last_name" class="block text-sm font-medium text-gray-700 mb-1">Apellido <span class="text-red-500">*</span></label>
        <input type="text" id="last_name" name="last_name" value="<%= c.last_name || '' %>" required
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none"
          placeholder="Apellido del cliente">
      </div>

      <!-- Phone -->
      <div>
        <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Teléfono <span class="text-red-500">*</span></label>
        <input type="tel" id="phone" name="phone" value="<%= c.phone || '' %>" required
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none"
          placeholder="+52 123 456 7890">
      </div>

      <!-- Phone 2 -->
      <div>
        <label for="phone2" class="block text-sm font-medium text-gray-700 mb-1">Teléfono 2</label>
        <input type="tel" id="phone2" name="phone2" value="<%= c.phone2 || '' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none"
          placeholder="Teléfono alternativo">
      </div>

      <!-- Email -->
      <div>
        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Correo Electrónico</label>
        <input type="email" id="email" name="email" value="<%= c.email || '' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none"
          placeholder="correo@ejemplo.com">
      </div>

      <!-- Status -->
      <div>
        <label for="status" class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
        <select id="status" name="status"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none">
          <option value="active" <%= (c.status || 'active') === 'active' ? 'selected' : '' %>>Activo</option>
          <option value="suspended" <%= c.status === 'suspended' ? 'selected' : '' %>>Suspendido</option>
          <option value="inactive" <%= c.status === 'inactive' ? 'selected' : '' %>>Inactivo</option>
        </select>
      </div>
    </div>
  </div>

  <!-- Address -->
  <div class="bg-white rounded-xl shadow-sm border">
    <div class="px-5 py-4 border-b bg-gray-50 rounded-t-xl">
      <h3 class="font-semibold text-gray-700 flex items-center gap-2">
        <i class="fas fa-map-marker-alt text-wisp-600"></i> Dirección
      </h3>
    </div>
    <div class="p-5 grid grid-cols-1 md:grid-cols-3 gap-4">
      <!-- Address -->
      <div class="md:col-span-3">
        <label for="address" class="block text-sm font-medium text-gray-700 mb-1">Dirección</label>
        <input type="text" id="address" name="address" value="<%= c.address || '' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none"
          placeholder="Calle, número, colonia...">
      </div>

      <!-- City -->
      <div>
        <label for="city" class="block text-sm font-medium text-gray-700 mb-1">Ciudad</label>
        <input type="text" id="city" name="city" value="<%= c.city || '' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none"
          placeholder="Ciudad">
      </div>

      <!-- Neighborhood -->
      <div class="md:col-span-2">
        <label for="neighborhood" class="block text-sm font-medium text-gray-700 mb-1">Colonia / Barrio</label>
        <input type="text" id="neighborhood" name="neighborhood" value="<%= c.neighborhood || '' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none"
          placeholder="Colonia o barrio">
      </div>
    </div>
  </div>

  <!-- GPS Location -->
  <div class="bg-white rounded-xl shadow-sm border">
    <div class="px-5 py-4 border-b bg-gray-50 rounded-t-xl">
      <h3 class="font-semibold text-gray-700 flex items-center gap-2">
        <i class="fas fa-map-pin text-wisp-600"></i> Ubicación GPS
      </h3>
    </div>
    <div class="p-5">
      <!-- Google Maps Link -->
      <div class="mb-4">
        <label for="google_maps_link" class="block text-sm font-medium text-gray-700 mb-1">
          <i class="fas fa-map-marker-alt text-red-500 mr-1"></i> Link de Google Maps
        </label>
        <div class="flex gap-2">
          <input type="text" id="google_maps_link" name="google_maps_link" value="<%= c.google_maps_link || '' %>"
            class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none"
            placeholder="Pega aquí el link de Google Maps...">
          <button type="button" onclick="parseGoogleMapsLink()"
            class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors flex items-center gap-1 whitespace-nowrap">
            <i class="fas fa-map-marker-alt"></i> Extraer
          </button>
        </div>
        <p class="text-xs text-gray-400 mt-1"><i class="fas fa-info-circle mr-1"></i> Abre Google Maps, busca la ubicación del cliente, copia el link y pégalo aquí.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
        <div>
          <label for="latitude" class="block text-sm font-medium text-gray-700 mb-1">Latitud</label>
          <input type="text" id="latitude" name="latitude" value="<%= c.latitude || '' %>"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none font-mono"
            placeholder="18.4861">
        </div>
        <div>
          <label for="longitude" class="block text-sm font-medium text-gray-700 mb-1">Longitud</label>
          <input type="text" id="longitude" name="longitude" value="<%= c.longitude || '' %>"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none font-mono"
            placeholder="-69.9312">
        </div>
        <div class="flex items-end gap-2">
          <button type="button" onclick="getGPSLocation()" id="gps-btn"
            class="bg-wisp-600 hover:bg-wisp-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors flex items-center gap-2">
            <i class="fas fa-crosshairs"></i> GPS
          </button>
          <button type="button" onclick="clearLocation()"
            class="border border-gray-300 text-gray-600 hover:bg-gray-50 px-3 py-2 rounded-lg text-sm transition-colors">
            <i class="fas fa-times"></i>
          </button>
        </div>
      </div>
      <p id="gps-status" class="text-sm text-gray-500 mb-3"></p>
      <div id="map" class="w-full rounded-lg border border-gray-200" style="height: 350px;"></div>
      <p class="text-xs text-gray-400 mt-2"><i class="fas fa-info-circle mr-1"></i> Pega un link de Google Maps, usa el botón GPS, o haz clic en el mapa.</p>
    </div>
  </div>

  <!-- Service / Plan -->
  <div class="bg-white rounded-xl shadow-sm border">
    <div class="px-5 py-4 border-b bg-gray-50 rounded-t-xl">
      <h3 class="font-semibold text-gray-700 flex items-center gap-2">
        <i class="fas fa-cube text-wisp-600"></i> Plan y Servicio
      </h3>
    </div>
    <div class="p-5 grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Plan -->
      <div>
        <label for="plan_id" class="block text-sm font-medium text-gray-700 mb-1">Plan <span class="text-red-500">*</span></label>
        <select id="plan_id" name="plan_id" required
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none">
          <option value="">Seleccionar plan...</option>
          <% plans.forEach(plan => { %>
            <option value="<%= plan.id %>" <%= String(c.plan_id) === String(plan.id) ? 'selected' : '' %>>
              <%= plan.name %> - <%= currency %><%= Number(plan.price).toFixed(2) %> (<%= plan.speed_down %>/<%= plan.speed_up %> Mbps)
            </option>
          <% }) %>
        </select>
      </div>

      <!-- Billing Day -->
      <div>
        <label for="billing_day" class="block text-sm font-medium text-gray-700 mb-1">Día de Facturación <span class="text-red-500">*</span></label>
        <select id="billing_day" name="billing_day" required
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none">
          <% for (let d = 1; d <= 28; d++) { %>
            <option value="<%= d %>" <%= Number(c.billing_day) === d ? 'selected' : '' %>><%= d %></option>
          <% } %>
        </select>
      </div>

      <!-- Installation Date -->
      <div>
        <label for="installation_date" class="block text-sm font-medium text-gray-700 mb-1">Fecha de Instalación</label>
        <input type="date" id="installation_date" name="installation_date" value="<%= c.installation_date || '' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none">
      </div>
    </div>
  </div>

  <!-- Connection / Technical -->
  <div class="bg-white rounded-xl shadow-sm border">
    <div class="px-5 py-4 border-b bg-gray-50 rounded-t-xl">
      <h3 class="font-semibold text-gray-700 flex items-center gap-2">
        <i class="fas fa-network-wired text-wisp-600"></i> Datos Técnicos de Conexión
      </h3>
    </div>
    <div class="p-5 grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Connection Type -->
      <div>
        <label for="connection_type" class="block text-sm font-medium text-gray-700 mb-1">Tipo de Conexión</label>
        <select id="connection_type" name="connection_type"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none"
          onchange="toggleConnectionFields()">
          <option value="pppoe" <%= (c.connection_type || 'pppoe') === 'pppoe' ? 'selected' : '' %>>PPPoE</option>
          <option value="static" <%= c.connection_type === 'static' ? 'selected' : '' %>>IP Estática</option>
        </select>
      </div>

      <!-- IP Address -->
      <div>
        <label for="ip_address" class="block text-sm font-medium text-gray-700 mb-1">Dirección IP</label>
        <input type="text" id="ip_address" name="ip_address" value="<%= c.ip_address || '' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none font-mono"
          placeholder="192.168.1.100">
      </div>

      <!-- PPPoE User -->
      <div id="pppoe_fields_user">
        <label for="pppoe_user" class="block text-sm font-medium text-gray-700 mb-1">Usuario PPPoE</label>
        <input type="text" id="pppoe_user" name="pppoe_user" value="<%= c.pppoe_user || '' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none font-mono"
          placeholder="usuario_pppoe">
      </div>

      <!-- PPPoE Password -->
      <div id="pppoe_fields_pass">
        <label for="pppoe_password" class="block text-sm font-medium text-gray-700 mb-1">Contraseña PPPoE</label>
        <div class="relative">
          <input type="password" id="pppoe_password" name="pppoe_password" value="<%= c.pppoe_password || '' %>"
            class="w-full px-3 py-2 pr-10 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none font-mono"
            placeholder="contraseña">
          <button type="button" onclick="togglePassword()" class="absolute inset-y-0 right-0 px-3 text-gray-400 hover:text-gray-600">
            <i id="pass-icon" class="fas fa-eye"></i>
          </button>
        </div>
      </div>

      <!-- MAC Address -->
      <div>
        <label for="mac_address" class="block text-sm font-medium text-gray-700 mb-1">Dirección MAC</label>
        <input type="text" id="mac_address" name="mac_address" value="<%= c.mac_address || '' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none font-mono uppercase"
          placeholder="AA:BB:CC:DD:EE:FF">
      </div>

      <!-- Router Name -->
      <div>
        <label for="router_name" class="block text-sm font-medium text-gray-700 mb-1">Nombre del Router</label>
        <input type="text" id="router_name" name="router_name" value="<%= c.router_name || '' %>"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none"
          placeholder="Router asignado">
      </div>
    </div>
  </div>

  <!-- Notes -->
  <div class="bg-white rounded-xl shadow-sm border">
    <div class="px-5 py-4 border-b bg-gray-50 rounded-t-xl">
      <h3 class="font-semibold text-gray-700 flex items-center gap-2">
        <i class="fas fa-sticky-note text-wisp-600"></i> Notas
      </h3>
    </div>
    <div class="p-5">
      <textarea id="notes" name="notes" rows="3"
        class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none resize-y"
        placeholder="Notas adicionales sobre el cliente..."><%= c.notes || '' %></textarea>
    </div>
  </div>

  <!-- Actions -->
  <div class="flex items-center justify-between">
    <a href="<%= isEdit ? '/clients/' + c.id : '/clients' %>" class="px-4 py-2.5 border border-gray-300 text-gray-600 hover:bg-gray-50 rounded-lg text-sm font-medium transition-colors">
      <i class="fas fa-arrow-left mr-1"></i> Cancelar
    </a>
    <button type="submit" class="bg-wisp-600 hover:bg-wisp-700 text-white px-6 py-2.5 rounded-lg text-sm font-medium transition-colors shadow-sm">
      <i class="fas fa-save mr-1"></i> <%= isEdit ? 'Guardar Cambios' : 'Crear Cliente' %>
    </button>
  </div>
</form>

<!-- Leaflet CSS & JS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
// --- Map initialization ---
let map, marker;
const defaultLat = <%= c.latitude || 18.4861 %>;
const defaultLng = <%= c.longitude || -69.9312 %>;
const hasLocation = <%= (c.latitude && c.longitude) ? 'true' : 'false' %>;

document.addEventListener('DOMContentLoaded', function() {
  map = L.map('map').setView([defaultLat, defaultLng], hasLocation ? 16 : 8);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap'
  }).addTo(map);

  if (hasLocation) {
    marker = L.marker([defaultLat, defaultLng], { draggable: true }).addTo(map);
    marker.on('dragend', function(e) {
      const pos = e.target.getLatLng();
      updateCoords(pos.lat, pos.lng);
    });
  }

  map.on('click', function(e) {
    setMarker(e.latlng.lat, e.latlng.lng);
  });
});

function setMarker(lat, lng) {
  if (marker) { marker.setLatLng([lat, lng]); }
  else {
    marker = L.marker([lat, lng], { draggable: true }).addTo(map);
    marker.on('dragend', function(e) {
      const pos = e.target.getLatLng();
      updateCoords(pos.lat, pos.lng);
    });
  }
  updateCoords(lat, lng);
  map.setView([lat, lng], 16);
}

function updateCoords(lat, lng) {
  document.getElementById('latitude').value = lat.toFixed(6);
  document.getElementById('longitude').value = lng.toFixed(6);
}

function getGPSLocation() {
  const btn = document.getElementById('gps-btn');
  const status = document.getElementById('gps-status');
  if (!navigator.geolocation) {
    status.innerHTML = '<span class="text-red-500"><i class="fas fa-exclamation-circle mr-1"></i>Tu navegador no soporta geolocalización</span>';
    return;
  }
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Obteniendo...';
  status.innerHTML = '<span class="text-blue-500"><i class="fas fa-satellite-dish mr-1"></i>Buscando señal GPS...</span>';

  navigator.geolocation.getCurrentPosition(
    function(pos) {
      setMarker(pos.coords.latitude, pos.coords.longitude);
      status.innerHTML = '<span class="text-green-600"><i class="fas fa-check-circle mr-1"></i>Ubicación obtenida (precisión: ' + Math.round(pos.coords.accuracy) + 'm)</span>';
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-crosshairs"></i> Obtener Ubicación';
    },
    function(err) {
      status.innerHTML = '<span class="text-red-500"><i class="fas fa-exclamation-circle mr-1"></i>Error: ' + err.message + '</span>';
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-crosshairs"></i> Obtener Ubicación';
    },
    { enableHighAccuracy: true, timeout: 15000, maximumAge: 0 }
  );
}

function clearLocation() {
  document.getElementById('latitude').value = '';
  document.getElementById('longitude').value = '';
  document.getElementById('google_maps_link').value = '';
  document.getElementById('gps-status').innerHTML = '';
  if (marker) { map.removeLayer(marker); marker = null; }
}

function parseGoogleMapsLink() {
  const link = document.getElementById('google_maps_link').value.trim();
  const status = document.getElementById('gps-status');
  if (!link) {
    status.innerHTML = '<span class="text-red-500"><i class="fas fa-exclamation-circle mr-1"></i>Pega un link de Google Maps primero</span>';
    return;
  }

  let lat, lng;

  // Pattern 1: @lat,lng in URL (most common)
  let match = link.match(/@(-?\d+\.?\d*),(-?\d+\.?\d*)/);
  if (match) { lat = parseFloat(match[1]); lng = parseFloat(match[2]); }

  // Pattern 2: ?q=lat,lng or ?ll=lat,lng
  if (!lat) {
    match = link.match(/[?&](?:q|ll|query)=(-?\d+\.?\d*)[,+](-?\d+\.?\d*)/);
    if (match) { lat = parseFloat(match[1]); lng = parseFloat(match[2]); }
  }

  // Pattern 3: /place/lat,lng
  if (!lat) {
    match = link.match(/\/place\/(-?\d+\.?\d*),(-?\d+\.?\d*)/);
    if (match) { lat = parseFloat(match[1]); lng = parseFloat(match[2]); }
  }

  // Pattern 4: maps/dir/lat,lng
  if (!lat) {
    match = link.match(/\/dir\/.*?\/(-?\d+\.?\d*),(-?\d+\.?\d*)/);
    if (match) { lat = parseFloat(match[1]); lng = parseFloat(match[2]); }
  }

  // Pattern 5: just coordinates pasted directly (lat,lng or lat, lng)
  if (!lat) {
    match = link.match(/^(-?\d+\.?\d*)\s*,\s*(-?\d+\.?\d*)$/);
    if (match) { lat = parseFloat(match[1]); lng = parseFloat(match[2]); }
  }

  if (lat && lng && lat >= -90 && lat <= 90 && lng >= -180 && lng <= 180) {
    setMarker(lat, lng);
    status.innerHTML = '<span class="text-green-600"><i class="fas fa-check-circle mr-1"></i>Ubicación extraída del link de Google Maps</span>';
  } else {
    status.innerHTML = '<span class="text-red-500"><i class="fas fa-exclamation-circle mr-1"></i>No se pudieron extraer las coordenadas. Intenta copiar el link completo de Google Maps.</span>';
  }
}

// --- Connection fields ---
function toggleConnectionFields() {
  const type = document.getElementById('connection_type').value;
  const pppoeUser = document.getElementById('pppoe_fields_user');
  const pppoePass = document.getElementById('pppoe_fields_pass');
  if (type === 'pppoe') {
    pppoeUser.style.display = '';
    pppoePass.style.display = '';
  } else {
    pppoeUser.style.display = 'none';
    pppoePass.style.display = 'none';
  }
}

function togglePassword() {
  const input = document.getElementById('pppoe_password');
  const icon = document.getElementById('pass-icon');
  if (input.type === 'password') {
    input.type = 'text';
    icon.classList.replace('fa-eye', 'fa-eye-slash');
  } else {
    input.type = 'password';
    icon.classList.replace('fa-eye-slash', 'fa-eye');
  }
}

// Initialize visibility on load
toggleConnectionFields();
</script>

<%- include('../partials/footer') %>
