<%- include('../partials/header', { currentPage: 'clients', pageTitle: client.first_name + ' ' + client.last_name }) %>

<% const currency = (settings && settings.currency) ? settings.currency : '$'; %>

<!-- Breadcrumb + Actions -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div class="flex items-center gap-2 text-sm text-gray-500">
    <a href="/clients" class="hover:text-wisp-600 transition-colors">Clientes</a>
    <i class="fas fa-chevron-right text-xs"></i>
    <span class="text-gray-700 font-medium"><%= client.first_name %> <%= client.last_name %></span>
  </div>
  <div class="flex items-center gap-2 flex-wrap">
    <% if (user.role === 'admin') { %>
    <a href="/clients/<%= client.id %>/edit" class="inline-flex items-center gap-1 bg-blue-600 hover:bg-blue-700 text-white px-3 py-2 rounded-lg text-sm font-medium transition-colors">
      <i class="fas fa-edit"></i> Editar
    </a>
    <% } %>
    <% if (client.phone) { %>
      <% const waPhone = client.phone.replace(/[^0-9]/g, ''); %>
      <% const waMsg = encodeURIComponent(`Hola ${client.first_name} ${client.last_name}, le saluda ${(settings && settings.company_name) || 'RYV Comunicaciones'}.`); %>
      <a href="https://wa.me/<%= waPhone %>?text=<%= waMsg %>" target="_blank" class="inline-flex items-center gap-1 bg-green-600 hover:bg-green-700 text-white px-3 py-2 rounded-lg text-sm font-medium transition-colors">
        <i class="fab fa-whatsapp"></i> WhatsApp
      </a>
    <% } %>
    <% if (user.role === 'admin') { %>
      <% if (client.status === 'active') { %>
        <form method="POST" action="/mikrotik/cut/<%= client.id %>" class="inline" onsubmit="return confirm('¿Cortar servicio a <%= client.first_name %> <%= client.last_name %>?')">
          <button type="submit" class="inline-flex items-center gap-1 bg-orange-500 hover:bg-orange-600 text-white px-3 py-2 rounded-lg text-sm font-medium transition-colors">
            <i class="fas fa-ban"></i> Cortar Servicio
          </button>
        </form>
      <% } else if (client.status === 'suspended') { %>
        <form method="POST" action="/mikrotik/reconnect/<%= client.id %>" class="inline" onsubmit="return confirm('¿Reconectar servicio a <%= client.first_name %> <%= client.last_name %>?')">
          <button type="submit" class="inline-flex items-center gap-1 bg-wisp-600 hover:bg-wisp-700 text-white px-3 py-2 rounded-lg text-sm font-medium transition-colors">
            <i class="fas fa-plug"></i> Reconectar
          </button>
        </form>
      <% } %>
      <form method="POST" action="/clients/<%= client.id %>/delete" class="inline" onsubmit="return confirmDelete(this, '<%= client.first_name %> <%= client.last_name %>')">
        <button type="submit" class="inline-flex items-center gap-1 bg-red-600 hover:bg-red-700 text-white px-3 py-2 rounded-lg text-sm font-medium transition-colors">
          <i class="fas fa-trash"></i> Eliminar
        </button>
      </form>
    <% } %>
  </div>
</div>

<!-- Balance Card -->
<div class="mb-6">
  <div class="bg-white rounded-xl shadow-sm border overflow-hidden">
    <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x">
      <!-- Pending (what they owe) -->
      <div class="p-5 text-center">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Deuda Pendiente</p>
        <p class="text-2xl font-bold <%= balance.pending > 0 ? 'text-red-600' : 'text-gray-400' %>">
          <%= currency %><%= Number(balance.pending).toFixed(2) %>
        </p>
        <p class="text-xs text-gray-400 mt-1">Facturas sin pagar</p>
      </div>
      <!-- Total Paid -->
      <div class="p-5 text-center">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Total Pagado</p>
        <p class="text-2xl font-bold text-wisp-600">
          <%= currency %><%= Number(balance.totalPaid).toFixed(2) %>
        </p>
        <p class="text-xs text-gray-400 mt-1">Todos los pagos</p>
      </div>
      <!-- Balance -->
      <div class="p-5 text-center">
        <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Balance</p>
        <% if (balance.balance > 0) { %>
          <p class="text-2xl font-bold text-green-600">+<%= currency %><%= Number(balance.balance).toFixed(2) %></p>
          <p class="text-xs text-green-500 mt-1"><i class="fas fa-check-circle mr-1"></i>Saldo a favor</p>
        <% } else if (balance.balance < 0) { %>
          <p class="text-2xl font-bold text-red-600"><%= currency %><%= Number(Math.abs(balance.balance)).toFixed(2) %></p>
          <p class="text-xs text-red-500 mt-1"><i class="fas fa-exclamation-circle mr-1"></i>Debe</p>
        <% } else { %>
          <p class="text-2xl font-bold text-gray-500"><%= currency %>0.00</p>
          <p class="text-xs text-gray-400 mt-1"><i class="fas fa-check-circle mr-1"></i>Al día</p>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Client Info Cards -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">

  <!-- Personal Info -->
  <div class="bg-white rounded-xl shadow-sm border">
    <div class="px-5 py-4 border-b bg-gray-50 rounded-t-xl flex items-center justify-between">
      <h3 class="font-semibold text-gray-700 flex items-center gap-2">
        <i class="fas fa-user text-wisp-600"></i> Datos Personales
      </h3>
      <% if (client.status === 'active') { %>
        <span class="bg-green-100 text-green-700 text-xs font-semibold px-2.5 py-1 rounded-full">Activo</span>
      <% } else if (client.status === 'suspended') { %>
        <span class="bg-red-100 text-red-700 text-xs font-semibold px-2.5 py-1 rounded-full">Suspendido</span>
      <% } else { %>
        <span class="bg-gray-100 text-gray-600 text-xs font-semibold px-2.5 py-1 rounded-full">Inactivo</span>
      <% } %>
    </div>
    <div class="p-5 space-y-3 text-sm">
      <div class="flex items-start gap-3">
        <i class="fas fa-phone w-4 text-center text-gray-400 mt-0.5"></i>
        <div>
          <p class="text-gray-700"><%= client.phone %></p>
          <% if (client.phone2) { %>
            <p class="text-gray-500 text-xs mt-0.5"><%= client.phone2 %> (alt.)</p>
          <% } %>
        </div>
      </div>
      <% if (client.cedula) { %>
      <div class="flex items-center gap-3">
        <i class="fas fa-id-card w-4 text-center text-gray-400"></i>
        <p class="text-gray-700 font-mono"><%= client.cedula %></p>
      </div>
      <% } %>
      <% if (client.email) { %>
      <div class="flex items-center gap-3">
        <i class="fas fa-envelope w-4 text-center text-gray-400"></i>
        <p class="text-gray-700"><%= client.email %></p>
      </div>
      <% } %>
      <% if (client.address || client.city || client.neighborhood) { %>
      <div class="flex items-start gap-3">
        <i class="fas fa-map-marker-alt w-4 text-center text-gray-400 mt-0.5"></i>
        <div>
          <% if (client.address) { %><p class="text-gray-700"><%= client.address %></p><% } %>
          <p class="text-gray-500 text-xs">
            <%= [client.neighborhood, client.city].filter(Boolean).join(', ') %>
          </p>
        </div>
      </div>
      <% } %>
      <% if (client.installation_date) { %>
      <div class="flex items-center gap-3">
        <i class="fas fa-calendar w-4 text-center text-gray-400"></i>
        <p class="text-gray-700">Instalación: <%= client.installation_date %></p>
      </div>
      <% } %>
    </div>
  </div>

  <!-- Services Summary -->
  <div class="bg-white rounded-xl shadow-sm border lg:col-span-2">
    <div class="px-5 py-4 border-b bg-gray-50 rounded-t-xl flex items-center justify-between">
      <h3 class="font-semibold text-gray-700 flex items-center gap-2">
        <i class="fas fa-cube text-wisp-600"></i> Servicios
        <span class="bg-wisp-100 text-wisp-700 text-xs font-semibold px-2 py-0.5 rounded-full"><%= services.length %></span>
      </h3>
      <% if (user.role === 'admin') { %>
      <button onclick="document.getElementById('add-service-modal').classList.remove('hidden')"
        class="text-sm bg-wisp-600 hover:bg-wisp-700 text-white px-3 py-1.5 rounded-lg font-medium transition-colors">
        <i class="fas fa-plus mr-1"></i> Agregar Servicio
      </button>
      <% } %>
    </div>
    <div class="divide-y">
      <% if (services.length === 0) { %>
        <div class="p-8 text-center">
          <i class="fas fa-cube text-gray-300 text-3xl mb-2"></i>
          <p class="text-gray-400">Sin servicios. Agrega uno para empezar.</p>
        </div>
      <% } %>
      <% services.forEach((svc, idx) => { %>
      <div class="p-4 hover:bg-gray-50">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1 flex-wrap">
              <span class="font-medium text-gray-800 text-sm">
                <i class="fas fa-wifi text-wisp-500 mr-1"></i>
                <%= svc.plan_name || 'Sin plan' %>
              </span>
              <% if (svc.label) { %>
                <span class="bg-blue-100 text-blue-700 text-xs px-2 py-0.5 rounded-full"><%= svc.label %></span>
              <% } %>
              <% if (svc.status === 'active') { %>
                <span class="bg-green-100 text-green-700 text-xs px-1.5 py-0.5 rounded-full">Activo</span>
              <% } else if (svc.status === 'suspended') { %>
                <span class="bg-red-100 text-red-700 text-xs px-1.5 py-0.5 rounded-full">Suspendido</span>
              <% } else { %>
                <span class="bg-gray-100 text-gray-600 text-xs px-1.5 py-0.5 rounded-full">Inactivo</span>
              <% } %>
            </div>
            <div class="flex items-center gap-4 text-xs text-gray-500 flex-wrap">
              <% if (svc.plan_price) { %>
                <span><i class="fas fa-dollar-sign mr-1"></i><%= currency %><%= Number(svc.plan_price).toFixed(2) %>/mes</span>
              <% } %>
              <% if (svc.speed_down) { %>
                <span><i class="fas fa-tachometer-alt mr-1"></i><%= svc.speed_down %>/<%= svc.speed_up %></span>
              <% } %>
              <span class="font-mono bg-gray-100 px-1.5 py-0.5 rounded uppercase"><%= svc.connection_type || 'pppoe' %></span>
              <% if (svc.ip_address) { %>
                <span class="font-mono"><i class="fas fa-globe mr-1"></i><%= svc.ip_address %></span>
              <% } %>
              <% if (svc.pppoe_user && svc.connection_type === 'pppoe') { %>
                <span class="font-mono"><i class="fas fa-user-cog mr-1"></i><%= svc.pppoe_user %></span>
              <% } %>
              <span><i class="fas fa-calendar-day mr-1"></i>Cobro: dia <%= svc.billing_day || 1 %></span>
            </div>
          </div>
          <% if (user.role === 'admin') { %>
          <div class="flex items-center gap-1 shrink-0">
            <button onclick="editService(<%= JSON.stringify(svc).replace(/"/g, '&quot;') %>)"
              class="text-blue-600 hover:bg-blue-50 p-1.5 rounded" title="Editar">
              <i class="fas fa-edit text-xs"></i>
            </button>
            <% if (svc.status === 'active') { %>
              <form method="POST" action="/mikrotik/cut/<%= client.id %>?service_id=<%= svc.id %>" class="inline"
                onsubmit="return confirm('Cortar este servicio?')">
                <button type="submit" class="text-orange-500 hover:bg-orange-50 p-1.5 rounded" title="Cortar">
                  <i class="fas fa-ban text-xs"></i>
                </button>
              </form>
            <% } else if (svc.status === 'suspended') { %>
              <form method="POST" action="/mikrotik/reconnect/<%= client.id %>?service_id=<%= svc.id %>" class="inline"
                onsubmit="return confirm('Reconectar este servicio?')">
                <button type="submit" class="text-green-600 hover:bg-green-50 p-1.5 rounded" title="Reconectar">
                  <i class="fas fa-plug text-xs"></i>
                </button>
              </form>
            <% } %>
            <form method="POST" action="/clients/<%= client.id %>/services/<%= svc.id %>/delete" class="inline"
              onsubmit="return confirm('Eliminar este servicio?')">
              <button type="submit" class="text-red-500 hover:bg-red-50 p-1.5 rounded" title="Eliminar">
                <i class="fas fa-trash text-xs"></i>
              </button>
            </form>
          </div>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</div>

<!-- Add/Edit Service Modal -->
<div id="add-service-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4" style="background:rgba(0,0,0,0.5)">
  <div class="bg-white rounded-xl shadow-xl w-full max-w-lg max-h-[90vh] overflow-y-auto">
    <div class="px-5 py-4 border-b bg-gray-50 rounded-t-xl flex items-center justify-between">
      <h3 id="service-modal-title" class="font-semibold text-gray-700">Agregar Servicio</h3>
      <button onclick="closeServiceModal()" class="text-gray-400 hover:text-gray-600"><i class="fas fa-times"></i></button>
    </div>
    <form id="service-form" method="POST" action="/clients/<%= client.id %>/services" class="p-5 space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Etiqueta (opcional)</label>
        <input type="text" name="label" id="svc-label" placeholder="Ej: Casa, Negocio, Oficina..."
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none">
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Plan <span class="text-red-500">*</span></label>
        <select name="plan_id" id="svc-plan" required
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none">
          <option value="">Seleccionar plan...</option>
          <% plans.forEach(plan => { %>
            <option value="<%= plan.id %>"><%= plan.name %> - <%= currency %><%= Number(plan.price).toFixed(2) %> (<%= plan.speed_down %>/<%= plan.speed_up %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Tipo Conexion</label>
          <select name="connection_type" id="svc-conntype"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none"
            onchange="toggleSvcPPPoE()">
            <option value="pppoe">PPPoE</option>
            <option value="static">IP Estatica</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Dia de Cobro</label>
          <select name="billing_day" id="svc-billingday"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none">
            <% for (let d = 1; d <= 28; d++) { %>
              <option value="<%= d %>"><%= d %></option>
            <% } %>
          </select>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">IP</label>
        <input type="text" name="ip_address" id="svc-ip" placeholder="192.168.1.100"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none font-mono">
      </div>
      <div id="svc-pppoe-fields">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Usuario PPPoE</label>
            <input type="text" name="pppoe_user" id="svc-pppoeuser" placeholder="usuario"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none font-mono">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Contrasena PPPoE</label>
            <input type="text" name="pppoe_password" id="svc-pppoepass" placeholder="contrasena"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none font-mono">
          </div>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">MAC</label>
          <input type="text" name="mac_address" id="svc-mac" placeholder="AA:BB:CC:DD:EE:FF"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none font-mono uppercase">
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Router</label>
          <input type="text" name="router_name" id="svc-router"
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none">
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Fecha Instalacion</label>
        <input type="date" name="installation_date" id="svc-instdate"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none">
      </div>
      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="closeServiceModal()" class="px-4 py-2 border border-gray-300 text-gray-600 rounded-lg text-sm">Cancelar</button>
        <button type="submit" class="bg-wisp-600 hover:bg-wisp-700 text-white px-5 py-2 rounded-lg text-sm font-medium"><i class="fas fa-save mr-1"></i> Guardar</button>
      </div>
    </form>
  </div>
</div>

<script>
function editService(svc) {
  document.getElementById('service-modal-title').textContent = 'Editar Servicio';
  document.getElementById('service-form').action = '/clients/<%= client.id %>/services/' + svc.id;
  document.getElementById('svc-label').value = svc.label || '';
  document.getElementById('svc-plan').value = svc.plan_id || '';
  document.getElementById('svc-conntype').value = svc.connection_type || 'pppoe';
  document.getElementById('svc-billingday').value = svc.billing_day || 1;
  document.getElementById('svc-ip').value = svc.ip_address || '';
  document.getElementById('svc-pppoeuser').value = svc.pppoe_user || '';
  document.getElementById('svc-pppoepass').value = svc.pppoe_password || '';
  document.getElementById('svc-mac').value = svc.mac_address || '';
  document.getElementById('svc-router').value = svc.router_name || '';
  document.getElementById('svc-instdate').value = svc.installation_date || '';
  toggleSvcPPPoE();
  document.getElementById('add-service-modal').classList.remove('hidden');
}
function closeServiceModal() {
  document.getElementById('add-service-modal').classList.add('hidden');
  document.getElementById('service-modal-title').textContent = 'Agregar Servicio';
  document.getElementById('service-form').action = '/clients/<%= client.id %>/services';
  document.getElementById('service-form').reset();
  toggleSvcPPPoE();
}
function toggleSvcPPPoE() {
  const t = document.getElementById('svc-conntype').value;
  document.getElementById('svc-pppoe-fields').style.display = t === 'pppoe' ? '' : 'none';
}
</script>

<!-- Location Map -->
<% if (client.latitude && client.longitude) { %>
<div class="bg-white rounded-xl shadow-sm border mb-6">
  <div class="px-5 py-4 border-b bg-gray-50 rounded-t-xl flex items-center justify-between">
    <h3 class="font-semibold text-gray-700 flex items-center gap-2">
      <i class="fas fa-map-pin text-wisp-600"></i> Ubicación del Cliente
    </h3>
    <a href="https://www.google.com/maps?q=<%= client.latitude %>,<%= client.longitude %>" target="_blank"
      class="text-sm text-wisp-600 hover:text-wisp-700 font-medium">
      <i class="fas fa-external-link-alt mr-1"></i> Abrir en Google Maps
    </a>
  </div>
  <div class="p-3">
    <div id="client-map" class="w-full rounded-lg" style="height: 300px;"></div>
    <p class="text-xs text-gray-400 mt-2 px-2">
      <i class="fas fa-map-marker-alt mr-1"></i> <%= client.latitude.toFixed(6) %>, <%= client.longitude.toFixed(6) %>
    </p>
  </div>
</div>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
  const map = L.map('client-map').setView([<%= client.latitude %>, <%= client.longitude %>], 16);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap'
  }).addTo(map);
  L.marker([<%= client.latitude %>, <%= client.longitude %>]).addTo(map)
    .bindPopup('<b><%= client.first_name %> <%= client.last_name %></b><br><%= client.address || "" %>').openPopup();
});
</script>
<% } %>

<!-- Notes -->
<% if (client.notes) { %>
<div class="bg-white rounded-xl shadow-sm border mb-6">
  <div class="px-5 py-4 border-b bg-gray-50 rounded-t-xl">
    <h3 class="font-semibold text-gray-700 flex items-center gap-2">
      <i class="fas fa-sticky-note text-wisp-600"></i> Notas
    </h3>
  </div>
  <div class="p-5 text-sm text-gray-700 whitespace-pre-wrap"><%= client.notes %></div>
</div>
<% } %>

<!-- Tabs -->
<div class="bg-white rounded-xl shadow-sm border overflow-hidden">
  <!-- Tab headers -->
  <div class="border-b flex overflow-x-auto">
    <button onclick="switchTab('invoices')" id="tab-invoices" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-wisp-600 text-wisp-700 whitespace-nowrap">
      <i class="fas fa-file-invoice-dollar mr-1"></i> Facturas
      <span class="ml-1 bg-gray-200 text-gray-600 text-xs px-1.5 py-0.5 rounded-full"><%= invoices.length %></span>
    </button>
    <button onclick="switchTab('payments')" id="tab-payments" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 whitespace-nowrap">
      <i class="fas fa-money-bill-wave mr-1"></i> Pagos
      <span class="ml-1 bg-gray-200 text-gray-600 text-xs px-1.5 py-0.5 rounded-full"><%= payments.length %></span>
    </button>
    <button onclick="switchTab('messages')" id="tab-messages" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 whitespace-nowrap">
      <i class="fab fa-whatsapp mr-1"></i> Mensajes
      <span class="ml-1 bg-gray-200 text-gray-600 text-xs px-1.5 py-0.5 rounded-full"><%= messages.length %></span>
    </button>
    <button onclick="switchTab('cuts')" id="tab-cuts" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 whitespace-nowrap">
      <i class="fas fa-ban mr-1"></i> Cortes
      <span class="ml-1 bg-gray-200 text-gray-600 text-xs px-1.5 py-0.5 rounded-full"><%= cuts.length %></span>
    </button>
  </div>

  <!-- Tab: Invoices -->
  <div id="panel-invoices" class="tab-panel">
    <% if (invoices.length === 0) { %>
      <div class="p-8 text-center">
        <i class="fas fa-file-invoice text-gray-300 text-4xl mb-3"></i>
        <p class="text-gray-400">No hay facturas registradas</p>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b">
              <th class="text-left px-4 py-3 font-semibold text-gray-600"># Factura</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Período</th>
              <th class="text-right px-4 py-3 font-semibold text-gray-600">Monto</th>
              <th class="text-center px-4 py-3 font-semibold text-gray-600">Estado</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Vencimiento</th>
              <th class="text-center px-4 py-3 font-semibold text-gray-600">Acciones</th>
            </tr>
          </thead>
          <tbody class="divide-y">
            <% invoices.forEach(inv => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-mono text-gray-700">#<%= inv.id %></td>
              <td class="px-4 py-3 text-gray-600"><%= inv.period || '--' %></td>
              <td class="px-4 py-3 text-right font-semibold text-gray-800"><%= currency %><%= Number(inv.amount || 0).toFixed(2) %></td>
              <td class="px-4 py-3 text-center">
                <% if (inv.status === 'paid') { %>
                  <span class="bg-green-100 text-green-700 text-xs font-semibold px-2 py-0.5 rounded-full">Pagada</span>
                <% } else if (inv.status === 'overdue') { %>
                  <span class="bg-red-100 text-red-700 text-xs font-semibold px-2 py-0.5 rounded-full">Vencida</span>
                <% } else { %>
                  <span class="bg-yellow-100 text-yellow-700 text-xs font-semibold px-2 py-0.5 rounded-full">Pendiente</span>
                <% } %>
              </td>
              <td class="px-4 py-3 text-gray-600"><%= inv.due_date || '--' %></td>
              <td class="px-4 py-3 text-center">
                <a href="/invoices/<%= inv.id %>" class="text-wisp-600 hover:text-wisp-700 text-xs font-medium"><i class="fas fa-eye mr-1"></i>Ver</a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- Tab: Payments -->
  <div id="panel-payments" class="tab-panel hidden">
    <% if (payments.length === 0) { %>
      <div class="p-8 text-center">
        <i class="fas fa-money-bill-wave text-gray-300 text-4xl mb-3"></i>
        <p class="text-gray-400">No hay pagos registrados</p>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b">
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Fecha</th>
              <th class="text-right px-4 py-3 font-semibold text-gray-600">Monto</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Método</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Factura</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Nota</th>
            </tr>
          </thead>
          <tbody class="divide-y">
            <% payments.forEach(pay => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 text-gray-700"><%= pay.created_at || pay.date || '--' %></td>
              <td class="px-4 py-3 text-right font-semibold text-green-600"><%= currency %><%= Number(pay.amount || 0).toFixed(2) %></td>
              <td class="px-4 py-3 text-gray-600">
                <% if (pay.method === 'cash') { %>
                  <span class="text-xs"><i class="fas fa-money-bill mr-1"></i>Efectivo</span>
                <% } else if (pay.method === 'transfer') { %>
                  <span class="text-xs"><i class="fas fa-exchange-alt mr-1"></i>Transferencia</span>
                <% } else { %>
                  <span class="text-xs"><%= pay.method || '--' %></span>
                <% } %>
              </td>
              <td class="px-4 py-3 text-gray-600">
                <% if (pay.invoice_id) { %>
                  <a href="/invoices/<%= pay.invoice_id %>" class="text-wisp-600 hover:text-wisp-700 font-mono">#<%= pay.invoice_id %></a>
                <% } else { %>
                  <span class="text-gray-400">--</span>
                <% } %>
              </td>
              <td class="px-4 py-3 text-gray-500 text-xs"><%= pay.notes || '' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>

  <!-- Tab: Messages -->
  <div id="panel-messages" class="tab-panel hidden">
    <% if (messages.length === 0) { %>
      <div class="p-8 text-center">
        <i class="fab fa-whatsapp text-gray-300 text-4xl mb-3"></i>
        <p class="text-gray-400">No hay mensajes enviados</p>
      </div>
    <% } else { %>
      <div class="divide-y">
        <% messages.forEach(msg => { %>
        <div class="p-4 hover:bg-gray-50">
          <div class="flex items-start justify-between">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1">
                <% if (msg.type === 'reminder') { %>
                  <span class="bg-yellow-100 text-yellow-700 text-xs font-medium px-2 py-0.5 rounded-full">Recordatorio</span>
                <% } else if (msg.type === 'cut_notice') { %>
                  <span class="bg-red-100 text-red-700 text-xs font-medium px-2 py-0.5 rounded-full">Aviso de Corte</span>
                <% } else { %>
                  <span class="bg-blue-100 text-blue-700 text-xs font-medium px-2 py-0.5 rounded-full"><%= msg.type || 'Mensaje' %></span>
                <% } %>
                <span class="text-xs text-gray-400"><%= msg.created_at || msg.sent_at || '' %></span>
              </div>
              <p class="text-sm text-gray-700"><%= msg.message || msg.content || '' %></p>
            </div>
            <div class="ml-3">
              <% if (msg.status === 'sent' || msg.status === 'delivered') { %>
                <span class="text-green-500 text-xs"><i class="fas fa-check-double"></i> Enviado</span>
              <% } else if (msg.status === 'failed') { %>
                <span class="text-red-500 text-xs"><i class="fas fa-times"></i> Fallido</span>
              <% } else { %>
                <span class="text-gray-400 text-xs"><i class="fas fa-clock"></i> Pendiente</span>
              <% } %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Tab: Service Cuts -->
  <div id="panel-cuts" class="tab-panel hidden">
    <% if (cuts.length === 0) { %>
      <div class="p-8 text-center">
        <i class="fas fa-ban text-gray-300 text-4xl mb-3"></i>
        <p class="text-gray-400">No hay cortes de servicio registrados</p>
      </div>
    <% } else { %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b">
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Fecha de Corte</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Motivo</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Reconexión</th>
              <th class="text-center px-4 py-3 font-semibold text-gray-600">Estado</th>
            </tr>
          </thead>
          <tbody class="divide-y">
            <% cuts.forEach(cut => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 text-gray-700"><%= cut.cut_date || cut.created_at || '--' %></td>
              <td class="px-4 py-3 text-gray-600"><%= cut.reason || 'Falta de pago' %></td>
              <td class="px-4 py-3 text-gray-600">
                <% if (cut.reconnected_at) { %>
                  <span class="text-green-600"><i class="fas fa-plug mr-1"></i><%= cut.reconnected_at %></span>
                <% } else { %>
                  <span class="text-gray-400">--</span>
                <% } %>
              </td>
              <td class="px-4 py-3 text-center">
                <% if (cut.reconnected_at) { %>
                  <span class="bg-green-100 text-green-700 text-xs font-semibold px-2 py-0.5 rounded-full">Reconectado</span>
                <% } else { %>
                  <span class="bg-red-100 text-red-700 text-xs font-semibold px-2 py-0.5 rounded-full">Cortado</span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<!-- Send WhatsApp Message -->
<div class="bg-white rounded-xl shadow-sm border mt-6">
  <div class="px-5 py-4 border-b bg-gray-50 rounded-t-xl">
    <h3 class="font-semibold text-gray-700 flex items-center gap-2">
      <i class="fab fa-whatsapp text-green-600"></i> Enviar Mensaje WhatsApp
    </h3>
  </div>
  <div class="p-5">
    <form method="POST" action="/whatsapp/send" class="flex flex-col sm:flex-row gap-3">
      <input type="hidden" name="client_id" value="<%= client.id %>">
      <input type="hidden" name="phone" value="<%= client.phone %>">
      <input type="text" name="message" placeholder="Escribir mensaje..."
        class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none"
        required>
      <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-5 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap">
        <i class="fab fa-whatsapp mr-1"></i> Enviar
      </button>
    </form>
  </div>
</div>

<script>
function switchTab(tab) {
  // Hide all panels
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
  // Reset all tab buttons
  document.querySelectorAll('.tab-btn').forEach(b => {
    b.classList.remove('border-wisp-600', 'text-wisp-700');
    b.classList.add('border-transparent', 'text-gray-500');
  });
  // Show selected panel
  document.getElementById('panel-' + tab).classList.remove('hidden');
  // Activate selected tab button
  const btn = document.getElementById('tab-' + tab);
  btn.classList.remove('border-transparent', 'text-gray-500');
  btn.classList.add('border-wisp-600', 'text-wisp-700');
}
</script>

<%- include('../partials/footer') %>
