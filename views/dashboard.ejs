<%- include('partials/header', { currentPage: 'dashboard', pageTitle: 'Dashboard' }) %>

<!-- Stats Cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-xl shadow-sm border p-5">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-500">Total Clientes</p>
        <p class="text-2xl font-bold text-gray-800"><%= totalClients %></p>
      </div>
      <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
        <i class="fas fa-users text-blue-600 text-xl"></i>
      </div>
    </div>
    <div class="mt-2 text-xs">
      <span class="text-green-600"><%= activeClients %> activos</span> &middot;
      <span class="text-red-600"><%= suspendedClients %> suspendidos</span>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border p-5">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-500">Ingresos del Mes</p>
        <p class="text-2xl font-bold text-green-600"><%= settings.currency || '$' %><%= monthlyIncome.toLocaleString('es', {minimumFractionDigits: 2}) %></p>
      </div>
      <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
        <i class="fas fa-dollar-sign text-green-600 text-xl"></i>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border p-5">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-500">Facturas Pendientes</p>
        <p class="text-2xl font-bold text-orange-600"><%= pendingInvoices %></p>
      </div>
      <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center">
        <i class="fas fa-file-invoice text-orange-600 text-xl"></i>
      </div>
    </div>
    <div class="mt-2 text-xs text-gray-500">
      Monto: <%= settings.currency || '$' %><%= pendingAmount.toLocaleString('es', {minimumFractionDigits: 2}) %>
    </div>
  </div>

  <div class="bg-white rounded-xl shadow-sm border p-5">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-500">Facturas Vencidas</p>
        <p class="text-2xl font-bold text-red-600"><%= overdueInvoices %></p>
      </div>
      <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center">
        <i class="fas fa-exclamation-triangle text-red-600 text-xl"></i>
      </div>
    </div>
  </div>
</div>

<!-- Quick Actions -->
<div class="bg-white rounded-xl shadow-sm border p-5 mb-6">
  <h3 class="font-semibold text-gray-700 mb-3">Acciones Rápidas</h3>
  <div class="flex flex-wrap gap-3">
    <a href="/clients/new" class="bg-teal-600 hover:bg-teal-700 text-white px-4 py-2 rounded-lg text-sm transition-colors">
      <i class="fas fa-user-plus mr-1"></i> Nuevo Cliente
    </a>
    <form method="POST" action="/invoices/generate" class="inline">
      <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm transition-colors">
        <i class="fas fa-file-invoice mr-1"></i> Generar Facturas del Mes
      </button>
    </form>
    <a href="/payments/new" class="bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg text-sm transition-colors">
      <i class="fas fa-money-bill mr-1"></i> Registrar Pago
    </a>
    <form method="POST" action="/whatsapp/send-reminders" class="inline">
      <button type="submit" class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-2 rounded-lg text-sm transition-colors">
        <i class="fab fa-whatsapp mr-1"></i> Enviar Recordatorios
      </button>
    </form>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Overdue clients -->
  <div class="bg-white rounded-xl shadow-sm border">
    <div class="p-5 border-b">
      <h3 class="font-semibold text-gray-700"><i class="fas fa-exclamation-circle text-red-500 mr-2"></i>Clientes con Mora</h3>
    </div>
    <div class="p-5">
      <% if (overdueClients.length === 0) { %>
        <p class="text-gray-400 text-sm text-center py-4">No hay clientes con mora</p>
      <% } else { %>
        <div class="space-y-3">
          <% overdueClients.forEach(c => { %>
          <div class="flex items-center justify-between p-3 bg-red-50 rounded-lg">
            <div>
              <p class="font-medium text-sm"><%= c.first_name %> <%= c.last_name %></p>
              <p class="text-xs text-gray-500"><%= c.phone %> &middot; Vence: <%= c.due_date %></p>
            </div>
            <div class="text-right">
              <p class="font-semibold text-red-600 text-sm"><%= settings.currency || '$' %><%= c.total.toFixed(2) %></p>
              <span class="text-xs px-2 py-0.5 rounded-full <%= c.status === 'suspended' ? 'bg-red-200 text-red-700' : 'bg-yellow-200 text-yellow-700' %>">
                <%= c.status === 'suspended' ? 'Suspendido' : 'Activo' %>
              </span>
            </div>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Recent payments -->
  <div class="bg-white rounded-xl shadow-sm border">
    <div class="p-5 border-b">
      <h3 class="font-semibold text-gray-700"><i class="fas fa-money-bill-wave text-green-500 mr-2"></i>Pagos Recientes</h3>
    </div>
    <div class="p-5">
      <% if (recentPayments.length === 0) { %>
        <p class="text-gray-400 text-sm text-center py-4">No hay pagos registrados</p>
      <% } else { %>
        <div class="space-y-3">
          <% recentPayments.forEach(p => { %>
          <div class="flex items-center justify-between p-3 bg-green-50 rounded-lg">
            <div>
              <p class="font-medium text-sm"><%= p.first_name %> <%= p.last_name %></p>
              <p class="text-xs text-gray-500"><%= p.created_at %></p>
            </div>
            <p class="font-semibold text-green-600"><%= settings.currency || '$' %><%= p.amount.toFixed(2) %></p>
          </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Plan Distribution -->
<div class="bg-white rounded-xl shadow-sm border mt-6">
  <div class="p-5 border-b">
    <h3 class="font-semibold text-gray-700"><i class="fas fa-chart-pie text-purple-500 mr-2"></i>Distribución por Plan</h3>
  </div>
  <div class="p-5">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <% planDistribution.forEach(p => { %>
      <div class="text-center p-3 bg-gray-50 rounded-lg">
        <p class="text-2xl font-bold text-teal-600"><%= p.count %></p>
        <p class="text-sm text-gray-600"><%= p.name %></p>
      </div>
      <% }) %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
