<%- include('../partials/header', { currentPage: 'invoices', pageTitle: 'Facturas' }) %>

<% const currency = (settings && settings.currency) ? settings.currency : '$'; %>

<!-- Top bar: title + actions -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div>
    <h3 class="text-xl font-bold text-gray-800">Facturas</h3>
    <p class="text-sm text-gray-500 mt-1"><%= invoices.length %> factura<%= invoices.length !== 1 ? 's' : '' %> encontrada<%= invoices.length !== 1 ? 's' : '' %></p>
  </div>
  <% if (user.role === 'admin') { %>
  <div class="flex items-center gap-2 flex-wrap">
    <a href="/invoices/new" class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors shadow-sm">
      <i class="fas fa-plus"></i> Nueva Factura
    </a>
    <form method="POST" action="/invoices/generate" class="inline">
      <button type="submit" class="inline-flex items-center gap-2 bg-wisp-600 hover:bg-wisp-700 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors shadow-sm"
        onclick="return confirm('¿Generar facturas del mes actual para todos los clientes activos?')">
        <i class="fas fa-file-invoice"></i> Generar Facturas
      </button>
    </form>
  </div>
  <% } %>
</div>

<!-- Filters -->
<div class="bg-white rounded-xl shadow-sm border p-5 mb-6">
  <form method="GET" action="/invoices" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <!-- Status filter -->
    <div>
      <label class="block text-xs font-medium text-gray-500 mb-1">Estado</label>
      <select name="status" class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none">
        <option value="">Todos</option>
        <option value="pending" <%= filters.status === 'pending' ? 'selected' : '' %>>Pendiente</option>
        <option value="paid" <%= filters.status === 'paid' ? 'selected' : '' %>>Pagada</option>
        <option value="cancelled" <%= filters.status === 'cancelled' ? 'selected' : '' %>>Cancelada</option>
        <option value="overdue" <%= filters.status === 'overdue' ? 'selected' : '' %>>Vencida</option>
      </select>
    </div>

    <!-- Month filter -->
    <div>
      <label class="block text-xs font-medium text-gray-500 mb-1">Mes</label>
      <input type="month" name="month" value="<%= filters.month || '' %>"
        class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none">
    </div>

    <!-- Search -->
    <div>
      <label class="block text-xs font-medium text-gray-500 mb-1">Buscar</label>
      <div class="relative">
        <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-gray-400"><i class="fas fa-search text-sm"></i></span>
        <input type="text" name="search" value="<%= filters.search || '' %>" placeholder="Nombre, # factura..."
          class="w-full pl-9 pr-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none">
      </div>
    </div>

    <!-- Filter buttons -->
    <div class="flex items-end gap-2">
      <button type="submit" class="flex-1 bg-wisp-600 hover:bg-wisp-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors">
        <i class="fas fa-filter mr-1"></i> Filtrar
      </button>
      <a href="/invoices" class="px-4 py-2 border border-gray-300 text-gray-600 hover:bg-gray-50 rounded-lg text-sm transition-colors">
        <i class="fas fa-times"></i>
      </a>
    </div>
  </form>
</div>

<!-- Invoices table -->
<div class="bg-white rounded-xl shadow-sm border overflow-hidden">
  <% if (invoices.length === 0) { %>
    <div class="p-12 text-center">
      <i class="fas fa-file-invoice-dollar text-gray-300 text-5xl mb-4"></i>
      <p class="text-gray-500 text-lg">No se encontraron facturas</p>
      <p class="text-gray-400 text-sm mt-1">Ajusta los filtros o genera facturas del mes</p>
    </div>
  <% } else { %>
    <!-- Desktop table -->
    <div class="hidden lg:block overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b">
            <th class="text-left px-4 py-3 font-semibold text-gray-600"># Factura</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600">Cliente</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600">Periodo</th>
            <th class="text-right px-4 py-3 font-semibold text-gray-600">Monto</th>
            <th class="text-center px-4 py-3 font-semibold text-gray-600">Estado</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600">Vencimiento</th>
            <th class="text-center px-4 py-3 font-semibold text-gray-600">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y">
          <% invoices.forEach(inv => { %>
          <%
            let statusClass = '';
            let statusLabel = '';
            const isOverdue = inv.status === 'pending' && inv.due_date && new Date(inv.due_date) < new Date();
            if (inv.status === 'paid') {
              statusClass = 'bg-green-100 text-green-700';
              statusLabel = 'Pagada';
            } else if (inv.status === 'cancelled') {
              statusClass = 'bg-gray-100 text-gray-600';
              statusLabel = 'Cancelada';
            } else if (isOverdue) {
              statusClass = 'bg-red-100 text-red-700';
              statusLabel = 'Vencida';
            } else {
              statusClass = 'bg-yellow-100 text-yellow-700';
              statusLabel = 'Pendiente';
            }
          %>
          <tr class="hover:bg-gray-50 transition-colors">
            <!-- Invoice number -->
            <td class="px-4 py-3">
              <a href="/invoices/<%= inv.id %>" class="font-mono font-medium text-gray-800 hover:text-wisp-600 transition-colors">
                #<%= inv.invoice_number || inv.id %>
              </a>
            </td>

            <!-- Client name -->
            <td class="px-4 py-3">
              <p class="text-gray-700"><%= inv.first_name %> <%= inv.last_name %></p>
            </td>

            <!-- Period -->
            <td class="px-4 py-3 text-gray-600"><%= inv.period_start && inv.period_end ? inv.period_start + ' a ' + inv.period_end : '--' %></td>

            <!-- Amount -->
            <td class="px-4 py-3 text-right font-semibold text-gray-800">
              <%= currency %><%= Number(inv.total || inv.amount || 0).toFixed(2) %>
            </td>

            <!-- Status -->
            <td class="px-4 py-3 text-center">
              <span class="inline-block <%= statusClass %> text-xs font-semibold px-2.5 py-1 rounded-full"><%= statusLabel %></span>
            </td>

            <!-- Due date -->
            <td class="px-4 py-3 text-gray-600">
              <% if (inv.due_date) { %>
                <span class="<%= isOverdue ? 'text-red-600 font-medium' : '' %>"><%= inv.due_date %></span>
              <% } else { %>
                <span class="text-gray-400">--</span>
              <% } %>
            </td>

            <!-- Actions -->
            <td class="px-4 py-3">
              <div class="flex items-center justify-center gap-1">
                <a href="/invoices/<%= inv.id %>" title="Ver detalle" class="p-2 text-gray-400 hover:text-wisp-600 hover:bg-wisp-50 rounded-lg transition-colors">
                  <i class="fas fa-eye"></i>
                </a>
                <% if (inv.status === 'pending') { %>
                  <form method="POST" action="/invoices/<%= inv.id %>/pay" class="inline" onsubmit="return confirm('¿Marcar esta factura como pagada?')">
                    <button type="submit" title="Registrar pago" class="p-2 text-gray-400 hover:text-green-600 hover:bg-green-50 rounded-lg transition-colors">
                      <i class="fas fa-check-circle"></i>
                    </button>
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Mobile cards -->
    <div class="lg:hidden divide-y">
      <% invoices.forEach(inv => { %>
      <%
        let mStatusClass = '';
        let mStatusLabel = '';
        const mIsOverdue = inv.status === 'pending' && inv.due_date && new Date(inv.due_date) < new Date();
        if (inv.status === 'paid') {
          mStatusClass = 'bg-green-100 text-green-700';
          mStatusLabel = 'Pagada';
        } else if (inv.status === 'cancelled') {
          mStatusClass = 'bg-gray-100 text-gray-600';
          mStatusLabel = 'Cancelada';
        } else if (mIsOverdue) {
          mStatusClass = 'bg-red-100 text-red-700';
          mStatusLabel = 'Vencida';
        } else {
          mStatusClass = 'bg-yellow-100 text-yellow-700';
          mStatusLabel = 'Pendiente';
        }
      %>
      <div class="p-4">
        <div class="flex items-start justify-between mb-2">
          <div>
            <a href="/invoices/<%= inv.id %>" class="font-mono font-medium text-gray-800 hover:text-wisp-600">
              #<%= inv.invoice_number || inv.id %>
            </a>
            <p class="text-sm text-gray-600 mt-0.5"><%= inv.first_name %> <%= inv.last_name %></p>
          </div>
          <span class="<%= mStatusClass %> text-xs font-semibold px-2 py-0.5 rounded-full"><%= mStatusLabel %></span>
        </div>
        <div class="text-sm text-gray-500 space-y-1">
          <p><i class="fas fa-calendar w-4 text-center mr-1"></i> <%= inv.period_start && inv.period_end ? inv.period_start + ' a ' + inv.period_end : '--' %></p>
          <p><i class="fas fa-clock w-4 text-center mr-1"></i> Vence: <%= inv.due_date || '--' %></p>
          <p class="font-semibold text-gray-800"><i class="fas fa-dollar-sign w-4 text-center mr-1"></i> <%= currency %><%= Number(inv.total || inv.amount || 0).toFixed(2) %></p>
        </div>
        <div class="flex items-center gap-2 mt-3 pt-3 border-t">
          <a href="/invoices/<%= inv.id %>" class="text-wisp-600 hover:text-wisp-700 text-sm font-medium"><i class="fas fa-eye mr-1"></i>Ver</a>
          <% if (inv.status === 'pending') { %>
            <form method="POST" action="/invoices/<%= inv.id %>/pay" class="inline ml-auto" onsubmit="return confirm('¿Marcar como pagada?')">
              <button type="submit" class="text-green-600 hover:text-green-700 text-sm font-medium"><i class="fas fa-check-circle mr-1"></i>Pagar</button>
            </form>
          <% } %>
        </div>
      </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
