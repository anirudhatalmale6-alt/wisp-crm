<%- include('../partials/header', { currentPage: 'invoices', pageTitle: 'Factura #' + (invoice.invoice_number || invoice.id) }) %>

<% const currency = (settings && settings.currency) ? settings.currency : '$'; %>
<%
  let statusClass = '';
  let statusLabel = '';
  const isOverdue = invoice.status === 'pending' && invoice.due_date && new Date(invoice.due_date) < new Date();
  if (invoice.status === 'paid') {
    statusClass = 'bg-green-100 text-green-700';
    statusLabel = 'Pagada';
  } else if (invoice.status === 'cancelled') {
    statusClass = 'bg-gray-100 text-gray-600';
    statusLabel = 'Cancelada';
  } else if (isOverdue) {
    statusClass = 'bg-red-100 text-red-700';
    statusLabel = 'Vencida';
  } else {
    statusClass = 'bg-yellow-100 text-yellow-700';
    statusLabel = 'Pendiente';
  }
%>

<!-- Breadcrumb + Actions -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div class="flex items-center gap-2 text-sm text-gray-500">
    <a href="/invoices" class="hover:text-wisp-600 transition-colors">Facturas</a>
    <i class="fas fa-chevron-right text-xs"></i>
    <span class="text-gray-700 font-medium">#<%= invoice.invoice_number || invoice.id %></span>
  </div>
  <div class="flex items-center gap-2 flex-wrap">
    <button onclick="window.print()" class="inline-flex items-center gap-1 bg-gray-600 hover:bg-gray-700 text-white px-3 py-2 rounded-lg text-sm font-medium transition-colors">
      <i class="fas fa-print"></i> Imprimir
    </button>
    <% if (invoice.phone) { %>
      <% const waPhoneInv = invoice.phone.replace(/[^0-9]/g, ''); %>
      <% const companyName = (settings && settings.company_name) || 'RYV Comunicaciones'; %>
      <% const invoiceTotal = Number(invoice.total || invoice.amount || 0).toFixed(2); %>
      <% if (invoice.status === 'paid') { %>
        <% const waMsgPaid = encodeURIComponent(`Hola ${invoice.first_name} ${invoice.last_name}, le saluda ${companyName}. Le confirmamos que su factura #${invoice.invoice_number || invoice.id} por ${currency}${invoiceTotal} ha sido pagada exitosamente. Gracias por su pago!`); %>
        <a href="https://wa.me/<%= waPhoneInv %>?text=<%= waMsgPaid %>" target="_blank" class="inline-flex items-center gap-1 bg-green-600 hover:bg-green-700 text-white px-3 py-2 rounded-lg text-sm font-medium transition-colors">
          <i class="fab fa-whatsapp"></i> Compartir por WhatsApp
        </a>
      <% } else if (invoice.status === 'pending') { %>
        <% const waMsgPending = encodeURIComponent(`Hola ${invoice.first_name} ${invoice.last_name}, le saluda ${companyName}. Le recordamos que tiene una factura pendiente #${invoice.invoice_number || invoice.id} por ${currency}${invoiceTotal}. Favor realizar el pago a la brevedad. Gracias.`); %>
        <a href="https://wa.me/<%= waPhoneInv %>?text=<%= waMsgPending %>" target="_blank" class="inline-flex items-center gap-1 bg-green-600 hover:bg-green-700 text-white px-3 py-2 rounded-lg text-sm font-medium transition-colors">
          <i class="fab fa-whatsapp"></i> Cobrar por WhatsApp
        </a>
      <% } %>
    <% } %>
    <% if (invoice.status === 'pending') { %>
      <form method="POST" action="/invoices/<%= invoice.id %>/pay" class="inline" onsubmit="return confirm('¿Marcar esta factura como pagada?')">
        <button type="submit" class="inline-flex items-center gap-1 bg-wisp-600 hover:bg-wisp-700 text-white px-3 py-2 rounded-lg text-sm font-medium transition-colors">
          <i class="fas fa-check-circle"></i> Registrar Pago
        </button>
      </form>
    <% } %>
  </div>
</div>

<!-- Printable Invoice -->
<div class="bg-white rounded-xl shadow-sm border overflow-hidden" id="invoice-print">
  <!-- Invoice Header -->
  <div class="bg-wisp-700 text-white px-8 py-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <div>
        <h2 class="text-2xl font-bold flex items-center gap-2">
          <i class="fas fa-wifi"></i> <%= (settings && settings.company_name) ? settings.company_name : 'WISP CRM' %>
        </h2>
        <% if (settings && settings.company_phone) { %>
          <p class="text-wisp-200 mt-1"><i class="fas fa-phone mr-1"></i> <%= settings.company_phone %></p>
        <% } %>
      </div>
      <div class="text-right">
        <p class="text-xl font-bold">FACTURA</p>
        <p class="text-wisp-200 font-mono text-lg">#<%= invoice.invoice_number || invoice.id %></p>
      </div>
    </div>
  </div>

  <div class="p-8">
    <!-- Client & Invoice Info -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
      <!-- Client Info -->
      <div>
        <h4 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Facturado a</h4>
        <p class="font-semibold text-gray-800 text-lg"><%= invoice.first_name %> <%= invoice.last_name %></p>
        <% if (invoice.phone) { %>
          <p class="text-sm text-gray-600 mt-1"><i class="fas fa-phone text-gray-400 mr-1"></i> <%= invoice.phone %></p>
        <% } %>
        <% if (invoice.email) { %>
          <p class="text-sm text-gray-600"><i class="fas fa-envelope text-gray-400 mr-1"></i> <%= invoice.email %></p>
        <% } %>
        <% if (invoice.address) { %>
          <p class="text-sm text-gray-600"><i class="fas fa-map-marker-alt text-gray-400 mr-1"></i> <%= invoice.address %></p>
        <% } %>
      </div>

      <!-- Invoice Details -->
      <div class="md:text-right">
        <div class="inline-block text-left">
          <div class="space-y-2 text-sm">
            <div class="flex justify-between gap-6">
              <span class="text-gray-500">Estado:</span>
              <span class="<%= statusClass %> text-xs font-semibold px-2.5 py-1 rounded-full"><%= statusLabel %></span>
            </div>
            <div class="flex justify-between gap-6">
              <span class="text-gray-500">Periodo:</span>
              <span class="text-gray-700 font-medium"><%= invoice.period_start && invoice.period_end ? invoice.period_start + ' a ' + invoice.period_end : '--' %></span>
            </div>
            <div class="flex justify-between gap-6">
              <span class="text-gray-500">Fecha de Emisión:</span>
              <span class="text-gray-700"><%= invoice.created_at || invoice.issue_date || '--' %></span>
            </div>
            <div class="flex justify-between gap-6">
              <span class="text-gray-500">Fecha de Vencimiento:</span>
              <span class="<%= isOverdue ? 'text-red-600 font-medium' : 'text-gray-700' %>"><%= invoice.due_date || '--' %></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Amount Breakdown -->
    <div class="border rounded-lg overflow-hidden mb-8">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b">
            <th class="text-left px-4 py-3 font-semibold text-gray-600">Concepto</th>
            <th class="text-right px-4 py-3 font-semibold text-gray-600">Monto</th>
          </tr>
        </thead>
        <tbody class="divide-y">
          <%
            // For custom invoices, concept is stored in notes (first line)
            let conceptText = invoice.plan_name || 'Servicio de Internet';
            let invoiceNotes = invoice.notes || '';
            if (!invoice.plan_name && invoice.notes) {
              const lines = invoice.notes.split('\n');
              conceptText = lines[0];
              invoiceNotes = lines.slice(1).join('\n').trim();
            }
          %>
          <tr>
            <td class="px-4 py-3">
              <p class="font-medium text-gray-800"><%= conceptText %></p>
              <% if (invoice.speed_down && invoice.speed_up) { %>
                <p class="text-xs text-gray-400 mt-0.5"><%= invoice.speed_down %>/<%= invoice.speed_up %> Mbps</p>
              <% } %>
              <% if (invoiceNotes) { %>
                <p class="text-xs text-gray-400 mt-0.5"><%= invoiceNotes %></p>
              <% } %>
            </td>
            <td class="px-4 py-3 text-right text-gray-800">
              <%= currency %><%= Number(invoice.amount || 0).toFixed(2) %>
            </td>
          </tr>
        </tbody>
        <tfoot>
          <% if (invoice.tax && Number(invoice.tax) > 0) { %>
          <tr class="border-t">
            <td class="px-4 py-2 text-right text-sm text-gray-500">Subtotal</td>
            <td class="px-4 py-2 text-right text-gray-700"><%= currency %><%= Number(invoice.amount || 0).toFixed(2) %></td>
          </tr>
          <tr>
            <td class="px-4 py-2 text-right text-sm text-gray-500">Impuesto (<%= settings.tax_rate || '0' %>%)</td>
            <td class="px-4 py-2 text-right text-gray-700"><%= currency %><%= Number(invoice.tax || 0).toFixed(2) %></td>
          </tr>
          <% } %>
          <tr class="border-t-2 bg-gray-50">
            <td class="px-4 py-3 text-right font-bold text-gray-800 text-base">Total</td>
            <td class="px-4 py-3 text-right font-bold text-gray-800 text-base"><%= currency %><%= Number(invoice.total || invoice.amount || 0).toFixed(2) %></td>
          </tr>
        </tfoot>
      </table>
    </div>

    <!-- Payment History -->
    <% if (payments && payments.length > 0) { %>
    <div class="mb-8">
      <h4 class="text-sm font-semibold text-gray-700 mb-3 flex items-center gap-2">
        <i class="fas fa-money-bill-wave text-green-500"></i> Historial de Pagos
      </h4>
      <div class="border rounded-lg overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b">
              <th class="text-left px-4 py-2 font-semibold text-gray-600">Fecha</th>
              <th class="text-right px-4 py-2 font-semibold text-gray-600">Monto</th>
              <th class="text-left px-4 py-2 font-semibold text-gray-600">Método</th>
              <th class="text-left px-4 py-2 font-semibold text-gray-600">Referencia</th>
            </tr>
          </thead>
          <tbody class="divide-y">
            <% payments.forEach(pay => { %>
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-2 text-gray-700"><%= pay.created_at || pay.date || '--' %></td>
              <td class="px-4 py-2 text-right font-semibold text-green-600"><%= currency %><%= Number(pay.amount || 0).toFixed(2) %></td>
              <td class="px-4 py-2 text-gray-600">
                <% if (pay.method === 'cash') { %>
                  <i class="fas fa-money-bill mr-1 text-green-500"></i>Efectivo
                <% } else if (pay.method === 'transfer') { %>
                  <i class="fas fa-exchange-alt mr-1 text-blue-500"></i>Transferencia
                <% } else if (pay.method === 'card') { %>
                  <i class="fas fa-credit-card mr-1 text-purple-500"></i>Tarjeta
                <% } else { %>
                  <i class="fas fa-ellipsis-h mr-1 text-gray-400"></i><%= pay.method || 'Otro' %>
                <% } %>
              </td>
              <td class="px-4 py-2 text-gray-500 text-xs"><%= pay.reference || pay.notes || '--' %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
    <% } %>

    <!-- Quick Pay Form (if pending) -->
    <% if (invoice.status === 'pending') { %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-5">
      <h4 class="text-sm font-semibold text-yellow-800 mb-3 flex items-center gap-2">
        <i class="fas fa-exclamation-triangle"></i> Factura Pendiente de Pago
      </h4>
      <form method="POST" action="/invoices/<%= invoice.id %>/pay" class="flex flex-col sm:flex-row gap-3">
        <select name="method" class="px-3 py-2 border border-yellow-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 outline-none bg-white">
          <option value="cash">Efectivo</option>
          <option value="transfer">Transferencia</option>
          <option value="card">Tarjeta</option>
          <option value="other">Otro</option>
        </select>
        <input type="text" name="reference" placeholder="Referencia o nota (opcional)"
          class="flex-1 px-3 py-2 border border-yellow-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 outline-none bg-white">
        <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-5 py-2 rounded-lg text-sm font-medium transition-colors whitespace-nowrap"
          onclick="return confirm('¿Confirmar pago de esta factura?')">
          <i class="fas fa-check-circle mr-1"></i> Registrar Pago
        </button>
      </form>
    </div>
    <% } %>
  </div>
</div>

<!-- Print styles -->
<style>
  @media print {
    body * { visibility: hidden; }
    #invoice-print, #invoice-print * { visibility: visible; }
    #invoice-print { position: absolute; left: 0; top: 0; width: 100%; box-shadow: none !important; border: none !important; border-radius: 0 !important; }
    .no-print { display: none !important; }
  }
</style>

<%- include('../partials/footer') %>
