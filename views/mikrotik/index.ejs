<%- include('../partials/header', { currentPage: 'mikrotik', pageTitle: 'MikroTik' }) %>

<%
  function sv(key) {
    return (settings && settings[key] && settings[key].value !== undefined) ? settings[key].value : (settings && settings[key] ? settings[key] : '');
  }
  const pending = typeof pendingCount !== 'undefined' ? pendingCount : 0;
  const queue = typeof queueItems !== 'undefined' ? queueItems : [];
%>

<!-- Top bar -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div>
    <h3 class="text-xl font-bold text-gray-800">MikroTik RouterOS</h3>
    <p class="text-sm text-gray-500 mt-1">Cola de acciones y registro de cortes de servicio</p>
  </div>
  <a href="/settings" class="inline-flex items-center gap-2 text-wisp-600 hover:text-wisp-700 text-sm font-medium transition-colors">
    <i class="fas fa-cog"></i> Ir a Configuración
  </a>
</div>

<!-- Status Cards -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
  <div class="bg-white rounded-xl shadow-sm border p-5">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-500">Acciones Pendientes</p>
        <p class="text-2xl font-bold <%= pending > 0 ? 'text-orange-600' : 'text-green-600' %>"><%= pending %></p>
      </div>
      <div class="w-12 h-12 <%= pending > 0 ? 'bg-orange-100' : 'bg-green-100' %> rounded-lg flex items-center justify-center">
        <i class="fas fa-clock <%= pending > 0 ? 'text-orange-600' : 'text-green-600' %> text-xl"></i>
      </div>
    </div>
  </div>
  <div class="bg-white rounded-xl shadow-sm border p-5">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-500">Corte Automático</p>
        <% if (sv('auto_cut_enabled') === '1') { %>
          <p class="text-lg font-bold text-green-600">Habilitado</p>
        <% } else { %>
          <p class="text-lg font-bold text-gray-400">Deshabilitado</p>
        <% } %>
      </div>
      <div class="w-12 h-12 <%= sv('auto_cut_enabled') === '1' ? 'bg-green-100' : 'bg-gray-100' %> rounded-lg flex items-center justify-center">
        <i class="fas fa-ban <%= sv('auto_cut_enabled') === '1' ? 'text-green-600' : 'text-gray-400' %> text-xl"></i>
      </div>
    </div>
  </div>
  <div class="bg-white rounded-xl shadow-sm border p-5">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm text-gray-500">Días de Gracia</p>
        <p class="text-lg font-bold text-gray-800"><%= sv('grace_days') || '0' %> días</p>
      </div>
      <div class="w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center">
        <i class="fas fa-clock text-yellow-600 text-xl"></i>
      </div>
    </div>
  </div>
</div>

<!-- How it works info -->
<div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-6">
  <div class="flex items-start gap-3">
    <i class="fas fa-info-circle text-blue-500 mt-0.5"></i>
    <div class="text-sm text-blue-700">
      <p class="font-semibold mb-1">Cómo funciona la integración</p>
      <p>El MikroTik revisa automáticamente cada 30 segundos si hay acciones pendientes (cortes o reconexiones) y las ejecuta.
      Cuando presionas "Cortar" o "Reconectar" en un cliente, la orden se agrega a la cola y el MikroTik la procesa en segundos.</p>
    </div>
  </div>
</div>

<!-- Action Queue -->
<% if (queue.length > 0) { %>
<div class="bg-white rounded-xl shadow-sm border overflow-hidden mb-6">
  <div class="px-5 py-4 border-b bg-gray-50 rounded-t-xl">
    <h3 class="font-semibold text-gray-700 flex items-center gap-2">
      <i class="fas fa-list-check text-wisp-600"></i> Cola de Acciones
      <% if (pending > 0) { %>
        <span class="bg-orange-100 text-orange-600 text-xs px-2 py-0.5 rounded-full"><%= pending %> pendientes</span>
      <% } %>
    </h3>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-gray-50 border-b">
          <th class="text-left px-4 py-3 font-semibold text-gray-600">Fecha</th>
          <th class="text-left px-4 py-3 font-semibold text-gray-600">Cliente</th>
          <th class="text-center px-4 py-3 font-semibold text-gray-600">Acción</th>
          <th class="text-left px-4 py-3 font-semibold text-gray-600">Detalle</th>
          <th class="text-center px-4 py-3 font-semibold text-gray-600">Estado</th>
        </tr>
      </thead>
      <tbody class="divide-y">
        <% queue.forEach(q => { %>
        <tr class="hover:bg-gray-50">
          <td class="px-4 py-3 text-gray-600 text-xs whitespace-nowrap"><%= q.created_at %></td>
          <td class="px-4 py-3 font-medium text-gray-800"><%= q.client_name %></td>
          <td class="px-4 py-3 text-center">
            <% if (q.action === 'cut') { %>
              <span class="bg-red-100 text-red-700 text-xs font-semibold px-2 py-0.5 rounded-full">Corte</span>
            <% } else { %>
              <span class="bg-green-100 text-green-700 text-xs font-semibold px-2 py-0.5 rounded-full">Reconexión</span>
            <% } %>
          </td>
          <td class="px-4 py-3 text-gray-500 text-xs font-mono">
            <% if (q.pppoe_user) { %>PPPoE: <%= q.pppoe_user %><% } %>
            <% if (q.ip_address) { %>IP: <%= q.ip_address %><% } %>
          </td>
          <td class="px-4 py-3 text-center">
            <% if (q.status === 'pending') { %>
              <span class="bg-orange-100 text-orange-600 text-xs font-semibold px-2 py-0.5 rounded-full">
                <i class="fas fa-clock mr-1"></i>Pendiente
              </span>
            <% } else { %>
              <span class="bg-green-100 text-green-700 text-xs font-semibold px-2 py-0.5 rounded-full">
                <i class="fas fa-check mr-1"></i>Ejecutado
              </span>
            <% } %>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<!-- Service Cuts Log -->
<div class="bg-white rounded-xl shadow-sm border overflow-hidden">
  <div class="px-5 py-4 border-b bg-gray-50 rounded-t-xl">
    <h3 class="font-semibold text-gray-700 flex items-center gap-2">
      <i class="fas fa-history text-wisp-600"></i> Registro de Cortes y Reconexiones
      <% if (typeof cuts !== 'undefined') { %>
        <span class="bg-gray-200 text-gray-600 text-xs px-2 py-0.5 rounded-full ml-1"><%= cuts.length %></span>
      <% } %>
    </h3>
  </div>

  <% if (typeof cuts === 'undefined' || cuts.length === 0) { %>
    <div class="p-12 text-center">
      <i class="fas fa-shield-alt text-gray-300 text-5xl mb-4"></i>
      <p class="text-gray-500 text-lg">No hay cortes de servicio registrados</p>
      <p class="text-gray-400 text-sm mt-1">Los cortes y reconexiones de servicio aparecerán aquí</p>
    </div>
  <% } else { %>
    <!-- Desktop table -->
    <div class="hidden lg:block overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b">
            <th class="text-left px-4 py-3 font-semibold text-gray-600">Fecha</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600">Cliente</th>
            <th class="text-center px-4 py-3 font-semibold text-gray-600">Acción</th>
            <th class="text-left px-4 py-3 font-semibold text-gray-600">Motivo</th>
            <th class="text-center px-4 py-3 font-semibold text-gray-600">Automático</th>
          </tr>
        </thead>
        <tbody class="divide-y">
          <% cuts.forEach(cut => { %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-4 py-3 text-gray-700 whitespace-nowrap"><%= cut.created_at || '--' %></td>
            <td class="px-4 py-3">
              <a href="/clients/<%= cut.client_id %>" class="font-medium text-gray-800 hover:text-wisp-600 transition-colors">
                <%= cut.first_name || '' %> <%= cut.last_name || '' %>
              </a>
            </td>
            <td class="px-4 py-3 text-center">
              <% if (cut.action === 'cut') { %>
                <span class="bg-red-100 text-red-700 text-xs font-semibold px-2.5 py-1 rounded-full"><i class="fas fa-ban mr-1"></i>Corte</span>
              <% } else { %>
                <span class="bg-green-100 text-green-700 text-xs font-semibold px-2.5 py-1 rounded-full"><i class="fas fa-plug mr-1"></i>Reconexión</span>
              <% } %>
            </td>
            <td class="px-4 py-3 text-gray-600"><%= cut.reason || 'Falta de pago' %></td>
            <td class="px-4 py-3 text-center">
              <% if (cut.automatic === 1) { %>
                <span class="bg-blue-100 text-blue-700 text-xs font-semibold px-2 py-0.5 rounded-full"><i class="fas fa-robot mr-1"></i>Auto</span>
              <% } else { %>
                <span class="bg-gray-100 text-gray-500 text-xs font-semibold px-2 py-0.5 rounded-full"><i class="fas fa-hand-pointer mr-1"></i>Manual</span>
              <% } %>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Mobile cards -->
    <div class="lg:hidden divide-y">
      <% cuts.forEach(cut => { %>
      <div class="p-4">
        <div class="flex items-start justify-between mb-2">
          <div>
            <a href="/clients/<%= cut.client_id %>" class="font-medium text-gray-800 hover:text-wisp-600">
              <%= cut.first_name || '' %> <%= cut.last_name || '' %>
            </a>
            <p class="text-xs text-gray-400 mt-0.5"><%= cut.created_at || '' %></p>
          </div>
          <% if (cut.action === 'cut') { %>
            <span class="bg-red-100 text-red-700 text-xs font-semibold px-2 py-0.5 rounded-full">Corte</span>
          <% } else { %>
            <span class="bg-green-100 text-green-700 text-xs font-semibold px-2 py-0.5 rounded-full">Reconexión</span>
          <% } %>
        </div>
        <div class="text-sm text-gray-500">
          <p><i class="fas fa-comment w-4 text-center mr-1"></i> <%= cut.reason || 'Falta de pago' %></p>
        </div>
      </div>
      <% }) %>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
