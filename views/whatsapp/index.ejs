<%- include('../partials/header', { currentPage: 'whatsapp', pageTitle: 'WhatsApp' }) %>

<!-- Top bar: title + bulk reminder -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
  <div>
    <h3 class="text-xl font-bold text-gray-800">WhatsApp</h3>
    <p class="text-sm text-gray-500 mt-1">Mensajes, plantillas y notificaciones</p>
  </div>
  <form method="POST" action="/whatsapp/send-reminders" class="inline">
    <button type="submit" class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors shadow-sm"
      onclick="return confirm('¿Enviar recordatorios de pago a todos los clientes con facturas pendientes?')">
      <i class="fab fa-whatsapp"></i> Enviar Recordatorios Masivos
    </button>
  </form>
</div>

<!-- Tabs -->
<div class="bg-white rounded-xl shadow-sm border overflow-hidden mb-6">
  <div class="border-b flex overflow-x-auto">
    <button onclick="switchTab('messages')" id="tab-messages" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-wisp-600 text-wisp-700 whitespace-nowrap">
      <i class="fas fa-comments mr-1"></i> Historial de Mensajes
      <span class="ml-1 bg-gray-200 text-gray-600 text-xs px-1.5 py-0.5 rounded-full"><%= messages.length %></span>
    </button>
    <button onclick="switchTab('templates')" id="tab-templates" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 whitespace-nowrap">
      <i class="fas fa-file-alt mr-1"></i> Plantillas
      <span class="ml-1 bg-gray-200 text-gray-600 text-xs px-1.5 py-0.5 rounded-full"><%= templates.length %></span>
    </button>
    <button onclick="switchTab('send')" id="tab-send" class="tab-btn px-5 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 whitespace-nowrap">
      <i class="fas fa-paper-plane mr-1"></i> Enviar Mensaje
    </button>
  </div>

  <!-- Tab: Message Log -->
  <div id="panel-messages" class="tab-panel">
    <% if (messages.length === 0) { %>
      <div class="p-12 text-center">
        <i class="fab fa-whatsapp text-gray-300 text-5xl mb-4"></i>
        <p class="text-gray-500 text-lg">No hay mensajes enviados</p>
        <p class="text-gray-400 text-sm mt-1">Los mensajes enviados a clientes aparecerán aquí</p>
      </div>
    <% } else { %>
      <!-- Desktop table -->
      <div class="hidden lg:block overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-gray-50 border-b">
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Fecha</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Cliente</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Teléfono</th>
              <th class="text-left px-4 py-3 font-semibold text-gray-600">Mensaje</th>
              <th class="text-center px-4 py-3 font-semibold text-gray-600">Estado</th>
            </tr>
          </thead>
          <tbody class="divide-y">
            <% messages.forEach(msg => { %>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-4 py-3 text-gray-700 whitespace-nowrap"><%= msg.created_at || msg.sent_at || '--' %></td>
              <td class="px-4 py-3">
                <% if (msg.client_id) { %>
                  <a href="/clients/<%= msg.client_id %>" class="font-medium text-gray-800 hover:text-wisp-600 transition-colors">
                    <%= msg.first_name || '' %> <%= msg.last_name || '' %>
                  </a>
                <% } else { %>
                  <span class="text-gray-700"><%= msg.first_name || '' %> <%= msg.last_name || '' %></span>
                <% } %>
              </td>
              <td class="px-4 py-3 text-gray-600 font-mono text-xs"><%= msg.phone || '--' %></td>
              <td class="px-4 py-3 text-gray-600 max-w-xs">
                <p class="truncate" title="<%= msg.message || msg.content || '' %>"><%= msg.message || msg.content || '' %></p>
              </td>
              <td class="px-4 py-3 text-center">
                <% if (msg.status === 'sent' || msg.status === 'delivered') { %>
                  <span class="inline-block bg-green-100 text-green-700 text-xs font-semibold px-2 py-0.5 rounded-full">
                    <i class="fas fa-check-double mr-1"></i>Enviado
                  </span>
                <% } else if (msg.status === 'failed') { %>
                  <span class="inline-block bg-red-100 text-red-700 text-xs font-semibold px-2 py-0.5 rounded-full">
                    <i class="fas fa-times mr-1"></i>Fallido
                  </span>
                <% } else { %>
                  <span class="inline-block bg-yellow-100 text-yellow-700 text-xs font-semibold px-2 py-0.5 rounded-full">
                    <i class="fas fa-clock mr-1"></i>Pendiente
                  </span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Mobile cards -->
      <div class="lg:hidden divide-y">
        <% messages.forEach(msg => { %>
        <div class="p-4">
          <div class="flex items-start justify-between mb-2">
            <div>
              <% if (msg.client_id) { %>
                <a href="/clients/<%= msg.client_id %>" class="font-medium text-gray-800 hover:text-wisp-600">
                  <%= msg.first_name || '' %> <%= msg.last_name || '' %>
                </a>
              <% } else { %>
                <span class="font-medium text-gray-800"><%= msg.first_name || '' %> <%= msg.last_name || '' %></span>
              <% } %>
              <p class="text-xs text-gray-400 mt-0.5"><%= msg.phone || '' %> &middot; <%= msg.created_at || msg.sent_at || '' %></p>
            </div>
            <% if (msg.status === 'sent' || msg.status === 'delivered') { %>
              <span class="bg-green-100 text-green-700 text-xs font-semibold px-2 py-0.5 rounded-full">Enviado</span>
            <% } else if (msg.status === 'failed') { %>
              <span class="bg-red-100 text-red-700 text-xs font-semibold px-2 py-0.5 rounded-full">Fallido</span>
            <% } else { %>
              <span class="bg-yellow-100 text-yellow-700 text-xs font-semibold px-2 py-0.5 rounded-full">Pendiente</span>
            <% } %>
          </div>
          <p class="text-sm text-gray-600 line-clamp-2"><%= msg.message || msg.content || '' %></p>
        </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Tab: Templates -->
  <div id="panel-templates" class="tab-panel hidden">
    <% if (templates.length === 0) { %>
      <div class="p-12 text-center">
        <i class="fas fa-file-alt text-gray-300 text-5xl mb-4"></i>
        <p class="text-gray-500 text-lg">No hay plantillas configuradas</p>
        <p class="text-gray-400 text-sm mt-1">Las plantillas se configuran en Configuración</p>
      </div>
    <% } else { %>
      <div class="p-5 space-y-4">
        <% templates.forEach(tmpl => { %>
        <div class="border rounded-lg overflow-hidden">
          <div class="bg-gray-50 px-4 py-3 border-b flex items-center justify-between">
            <div>
              <h4 class="font-semibold text-gray-700 text-sm"><%= tmpl.name %></h4>
              <% if (tmpl.category) { %>
                <span class="text-xs text-gray-400"><%= tmpl.category %></span>
              <% } %>
            </div>
            <span class="bg-wisp-50 text-wisp-700 text-xs font-medium px-2 py-0.5 rounded-full"><%= tmpl.category || 'General' %></span>
          </div>
          <form method="POST" action="/whatsapp/templates/<%= tmpl.id %>" class="p-4">
            <textarea name="content" rows="4"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none resize-y font-mono"
            ><%= tmpl.content || '' %></textarea>
            <div class="flex items-center justify-between mt-3">
              <p class="text-xs text-gray-400">
                Variables: <code class="bg-gray-100 px-1 rounded">{nombre}</code>
                <code class="bg-gray-100 px-1 rounded">{monto}</code>
                <code class="bg-gray-100 px-1 rounded">{fecha_vencimiento}</code>
                <code class="bg-gray-100 px-1 rounded">{empresa}</code>
              </p>
              <button type="submit" class="bg-wisp-600 hover:bg-wisp-700 text-white px-4 py-1.5 rounded-lg text-sm font-medium transition-colors">
                <i class="fas fa-save mr-1"></i> Guardar
              </button>
            </div>
          </form>
        </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <!-- Tab: Send Custom Message -->
  <div id="panel-send" class="tab-panel hidden">
    <div class="p-5">
      <form method="POST" action="/whatsapp/send" class="space-y-4">
        <!-- Client selector -->
        <div>
          <label for="send_client_id" class="block text-sm font-medium text-gray-700 mb-1">Cliente <span class="text-red-500">*</span></label>
          <select id="send_client_id" name="client_id" required
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none"
            onchange="updatePhone()">
            <option value="">Seleccionar cliente...</option>
            <%
              // Get unique clients from messages or use a separate list if available
              const clientList = [];
              const seenIds = new Set();
              messages.forEach(m => {
                if (m.client_id && !seenIds.has(m.client_id)) {
                  seenIds.add(m.client_id);
                  clientList.push({ id: m.client_id, name: (m.first_name || '') + ' ' + (m.last_name || ''), phone: m.phone || '' });
                }
              });
            %>
            <% clientList.forEach(c => { %>
              <option value="<%= c.id %>" data-phone="<%= c.phone %>"><%= c.name %> - <%= c.phone %></option>
            <% }) %>
          </select>
        </div>

        <!-- Phone (hidden, auto-filled) -->
        <input type="hidden" id="send_phone" name="phone" value="">

        <!-- Message -->
        <div>
          <label for="send_message" class="block text-sm font-medium text-gray-700 mb-1">Mensaje <span class="text-red-500">*</span></label>
          <textarea id="send_message" name="message" rows="5" required
            class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-wisp-500 focus:border-wisp-500 outline-none resize-y"
            placeholder="Escriba el mensaje que desea enviar al cliente..."></textarea>
          <p class="text-xs text-gray-400 mt-1">El mensaje se enviará por la API de WhatsApp Business</p>
        </div>

        <!-- Quick template buttons -->
        <% if (templates.length > 0) { %>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-2">Usar plantilla:</label>
          <div class="flex flex-wrap gap-2">
            <% templates.forEach(tmpl => { %>
              <button type="button" onclick="useTemplate('<%= tmpl.content ? tmpl.content.replace(/'/g, "\\'").replace(/\n/g, '\\n') : '' %>')"
                class="px-3 py-1.5 bg-gray-100 hover:bg-wisp-50 text-gray-700 hover:text-wisp-700 text-xs rounded-full border transition-colors">
                <i class="fas fa-file-alt mr-1"></i> <%= tmpl.name %>
              </button>
            <% }) %>
          </div>
        </div>
        <% } %>

        <div class="flex justify-end">
          <button type="submit" class="bg-green-600 hover:bg-green-700 text-white px-6 py-2.5 rounded-lg text-sm font-medium transition-colors shadow-sm">
            <i class="fab fa-whatsapp mr-1"></i> Enviar Mensaje
          </button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- WhatsApp Configuration Status -->
<div class="bg-white rounded-xl shadow-sm border overflow-hidden">
  <div class="px-5 py-4 border-b bg-gray-50 rounded-t-xl">
    <h3 class="font-semibold text-gray-700 flex items-center gap-2">
      <i class="fab fa-whatsapp text-green-600"></i> Estado de Configuración
    </h3>
  </div>
  <div class="p-5">
    <% if (settings && settings.whatsapp_enabled && settings.whatsapp_enabled.value === '1') { %>
      <div class="flex items-center gap-3 text-sm">
        <span class="w-3 h-3 bg-green-500 rounded-full"></span>
        <span class="text-green-700 font-medium">WhatsApp Business API configurada y activa</span>
      </div>
      <% if (settings.whatsapp_phone_id) { %>
        <p class="text-xs text-gray-400 mt-2 ml-6">Phone ID: <%= settings.whatsapp_phone_id.value || '--' %></p>
      <% } %>
    <% } else { %>
      <div class="flex items-center gap-3 text-sm">
        <span class="w-3 h-3 bg-gray-400 rounded-full"></span>
        <span class="text-gray-500">WhatsApp Business API no configurada</span>
      </div>
      <a href="/settings" class="inline-flex items-center gap-1 mt-3 ml-6 text-wisp-600 hover:text-wisp-700 text-sm font-medium">
        <i class="fas fa-cog mr-1"></i> Ir a Configuración
      </a>
    <% } %>
  </div>
</div>

<script>
function switchTab(tab) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
  document.querySelectorAll('.tab-btn').forEach(b => {
    b.classList.remove('border-wisp-600', 'text-wisp-700');
    b.classList.add('border-transparent', 'text-gray-500');
  });
  document.getElementById('panel-' + tab).classList.remove('hidden');
  const btn = document.getElementById('tab-' + tab);
  btn.classList.remove('border-transparent', 'text-gray-500');
  btn.classList.add('border-wisp-600', 'text-wisp-700');
}

function updatePhone() {
  const select = document.getElementById('send_client_id');
  const phoneInput = document.getElementById('send_phone');
  const option = select.options[select.selectedIndex];
  phoneInput.value = option ? (option.dataset.phone || '') : '';
}

function useTemplate(content) {
  document.getElementById('send_message').value = content.replace(/\\n/g, '\n');
}
</script>

<%- include('../partials/footer') %>
